Código Duplicado — Tratamento de Erros de Auth

Situação atual: Existe checkAuthError em main.ts e handleAuthError em chat.tsx — lógica quase idêntica duplicada em dois arquivos. Além disso, isMasterUser é buscado independentemente no ChatProvider via RPC, sendo que isMaster já existe no AppStore.

Recomendação:

// lib/supabase/authHelpers.ts
export const isAuthError = (err: any): boolean => {
  return (
    err?.code === 'PGRST303' ||
    err?.message?.includes('JWT expired') ||
    err?.status === 401
  )
}

export const handleAuthError = (err: any): boolean => {
  if (!isAuthError(err)) return false
  supabase.auth.signOut()
  toast({ title: 'Sessão Expirada', variant: 'destructive' })
  return true
}

